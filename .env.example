# Example environment variables file.
# Rename this file to .env and fill the values.

TOKEN= #Your Discord bot Token
DATABASE_URL= #Your Turso libSQL URL (libsql://...)
DATABASE_PASSWORD= #Your Turso Auth Token
DATABASE_LOCAL_PATH= # (Optional) Path to local db file. Default: ./data/alya.db
DATABASE_SYNC_INTERVAL= # (Optional) Sync interval in seconds. Default: 3600 (1 hour)
OPENROUTER_API_KEY= #Your OpenRouter API Key (if you want to use OpenRouter as your LLM provider)
GEMINI_KEYS=xxx,xxx #Your Gemini API Key (if you want to use Gemini as your LLM provider. Support loadbalance)

LASTFM_API_KEY=xxx,xxx #You can add 1 or more for loadbalance (depend what you need)