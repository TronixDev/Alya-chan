{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "soundy",
  "version": "2.0.1",
  "description": "A powerful music bot built with Seyfert and lavalink-client to play high quality music in your Discord server for free.",
  "author": "iaMJ",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/idMJA/Alya-chan",
  "repository": {
    "type": "git",
    "url": "https://github.com/idMJA/Alya-chan"
  },
  "bugs": {
    "url": "https://github.com/idMJA/Alya-chan/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "start": "dotenvx run -- bun run src/index.ts",
    "dev": "dotenvx run -- bun run --watch src/index.ts",
    "build": "tsup",
    "build:exe-all": "bun scripts/build.ts",
    "format": "biome format --write ./src",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenvx run -- drizzle-kit generate",
    "db:migrate": "dotenvx run -- drizzle-kit migrate",
    "db:studio": "dotenvx run -- drizzle-kit studio",
    "db:push": "dotenvx run -- drizzle-kit push"
  },
  "lint-staged": {
    "*.ts": ["bun format"]
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.50.1",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@libsql/client": "^0.15.15",
    "@napi-rs/canvas": "^0.1.80",
    "@top-gg/sdk": "^3.1.6",
    "axios": "^1.12.2",
    "canvacord": "^6.0.3",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.4.7",
    "genius-lyrics": "^4.4.7",
    "jsonwebtoken": "^9.0.2",
    "lavalink-client": "^2.6.1",
    "lowdb": "^7.0.1",
    "openai": "^5.22.0",
    "seyfert": "^3.2.7-dev-17656890690.0",
    "yunaforseyfert": "^1.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/bun": "^1.2.22",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild"
  ],
  "keywords": [
    "discord",
    "bot",
    "music",
    "lavalink",
    "seyfert",
    "typescript",
    "discord-bot",
    "music-bot"
  ]
}
